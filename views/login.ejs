<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MedCure · Login</title>

    <!-- ✅ FIXED FONT LINK -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #fcf7f2;
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            color: #3e3a37;
        }

        :root {
            --primary: #b35e3a;
            --primary-light: #e6c7b2;
            --border-warm: #edd9cb;
        }

        .login-container {
            background: white;
            padding: 40px;
            border-radius: 40px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 10px 30px rgba(180, 100, 60, 0.15);
            border: 1px solid var(--border-warm);
        }

        .logo {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 20px;
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
        }

        input {
            width: 100%;
            padding: 14px;
            margin-bottom: 15px;
            border-radius: 30px;
            border: 1px solid var(--border-warm);
            outline: none;
            font-size: 1rem;
        }

        input:focus {
            border-color: var(--primary);
        }

        button {
            width: 100%;
            padding: 14px;
            border-radius: 30px;
            border: none;
            background: var(--primary);
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #9e4f2f;
        }

        .error {
            color: red;
            text-align: center;
            margin-bottom: 10px;
        }

        .signup-link {
            text-align: center;
            margin-top: 15px;
            font-size: 0.9rem;
        }

        .signup-link a {
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
        }
    </style>
</head>

<body>

    <div class="login-container">
        <div class="logo">MedCure</div>

        <h2>Login</h2>

        <!-- ✅ Error Message -->
        <% if (message) { %>
            <div class="error">
                <%= message %>
            </div>
            <% } %>

                <!-- ✅ Login Form -->
                <form action="/login" method="POST">

                    <!-- ✅ NEW NAME FIELD -->
                    <input type="text" name="name" placeholder="Full Name" required>

                    <input type="text" name="phone" placeholder="Phone Number" required>

                    <input type="password" name="password" placeholder="Password" required>

                    <button type="submit">Login</button>
                </form>

                <div class="signup-link">
                    Don't have an account? <a href="/signup">Sign up</a>
                </div>
    </div>
    <script>
        function storeUser() {
            const name = document.querySelector('input[name="name"]').value;
            const phone = document.querySelector('input[name="phone"]').value;

            const userData = {
                name: name,
                phone: phone,
                loggedIn: true
            };

            // ✅ Store user properly
            localStorage.setItem("user", JSON.stringify(userData));

            // ✅ OPTIONAL: keep this if you want
            localStorage.setItem("userLoggedIn", "true");

            // ✅ HANDLE REDIRECT AFTER LOGIN
            const redirect = localStorage.getItem("redirectAfterLogin");

            if (redirect) {
                localStorage.removeItem("redirectAfterLogin");
                window.location.href = redirect;
            } else {
                window.location.href = "/"; // default home
            }

            // ❗ IMPORTANT: stop normal form submit
            return false;
        }
    </script>


</body>

</html>